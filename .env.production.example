# Frontend build-time public env
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=replace-me-public-anon-key
VITE_BFF_URL=/api
VITE_ENABLE_DEV_AUTO_LOGIN=false

# BFF runtime env
NODE_ENV=production
BFF_HOST=0.0.0.0
BFF_PORT=8787
BFF_LOG_LEVEL=info
BFF_SERVICE_NAME=@wos/bff

# Supabase/database env
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-me-public-anon-key

# Security/auth/CORS env
BFF_CORS_ORIGIN=http://localhost:8080

# Docker port config
WEB_PORT=8080
