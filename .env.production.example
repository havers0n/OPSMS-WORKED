# Production template for the first manual VPS deployment.
# Copy this file to .env.production on the server only, then fill real values there.
# Never commit .env.production or production secrets.

# Frontend build-time public env. Use the public Supabase URL and anon key only.
# Never put a service-role key in VITE_* variables.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace-me-public-anon-key
VITE_BFF_URL=/api
VITE_ENABLE_DEV_AUTO_LOGIN=false

# BFF runtime env. BFF listens inside the Compose network only.
NODE_ENV=production
BFF_HOST=0.0.0.0
BFF_PORT=8787
BFF_LOG_LEVEL=info
BFF_SERVICE_NAME=@wos/bff

# Supabase/database env. The BFF currently uses the anon key and forwards
# user bearer tokens for user-scoped requests.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-me-public-anon-key

# Security/auth/CORS env. Must match the final public browser origin exactly.
# Examples:
# BFF_CORS_ORIGIN=https://wos.example.com
# BFF_CORS_ORIGIN=http://YOUR_SERVER_IP:8080
BFF_CORS_ORIGIN=https://your-public-hostname.example

# Docker port config. If a system Nginx/Caddy reverse proxy is used, prefer
# binding the Compose web port to 127.0.0.1 in docker-compose.prod.yml.
WEB_PORT=8080
