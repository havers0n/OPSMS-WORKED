# Production runtime environment template.
# Copy values from the deployed environment, not from local development files.

# BFF runtime
BFF_PORT=8787
BFF_HOST=0.0.0.0
BFF_LOG_LEVEL=info
BFF_CORS_ORIGIN=https://app.example.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-production-anon-key

# Frontend build/runtime public config
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-production-anon-key
VITE_BFF_URL=https://api.example.com/api
VITE_ENABLE_DEV_AUTO_LOGIN=false

# CI-only build placeholders are defined in .github/workflows/ci.yml.
# Playwright/E2E and Supabase SQL test environment variables are intentionally
# not part of the first basic CI workflow.
