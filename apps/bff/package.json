{
  "name": "@wos/bff",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env.local --import tsx/esm --watch --watch-preserve-output src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/apps/bff/src/server.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "sync:products": "node dist/apps/bff/src/scripts/sync-products.js",
    "sync:products:local": "node --env-file=.env.local --import tsx/esm src/scripts/sync-products.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^10.0.0",
    "@supabase/supabase-js": "^2.50.0",
    "bwip-js": "^4.11.1",
    "fastify": "^5.2.1",
    "pdf-lib": "^1.17.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
