{
  "name": "@wos/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "storybook": "storybook dev -p 6006 --no-open",
    "storybook:build": "storybook build",
    "storybook:smoke": "storybook dev --ci --smoke-test -p 6006",
    "lint": "npm run runtime:migration:legacy-imports:check && eslint src --max-warnings 0 && tsc -p tsconfig.json --noEmit",
    "runtime:migration:legacy-imports:check": "node ./scripts/check-runtime-legacy-imports.mjs",
    "runtime:migration:pr5:check": "bash -lc \"test -f src/warehouse/editor/model/editor-selectors.ts && ! rg -n '@/entities/layout-version/model/(editor-selectors|editor-store|editor-store-helpers|editor-types|camera-store|mode-store|interaction-store|use-semantic-zoom|storage-workflow-actions)' src && ! rg --files src/entities/layout-version/model | rg '/(editor-selectors|editor-store|editor-store-helpers|editor-types|camera-store|mode-store|interaction-store|use-semantic-zoom|storage-workflow-actions)\\\\.ts$'\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:e2e": "npm run test:e2e:smoke",
    "test:e2e:smoke": "playwright test e2e/auth-runtime.spec.ts e2e/layout-geometry.spec.ts",
    "test:e2e:critical": "playwright test e2e/auth-runtime.spec.ts e2e/layout-geometry.spec.ts e2e/layout-lifecycle.spec.ts e2e/warehouse-setup.spec.ts",
    "test:e2e:functional": "npm run test:e2e:critical",
    "test:e2e:warehouse": "playwright test e2e/layout-lifecycle.spec.ts e2e/warehouse-setup.spec.ts",
    "test:e2e:storage": "playwright test e2e/storage-presets-partial-failed.spec.ts --reporter=line",
    "perf:dl1": "playwright test e2e/performance/dl1-fps.spec.ts --reporter=line",
    "perf:dl1:diagnostics": "playwright test e2e/performance/dl1-diagnostics.spec.ts --reporter=line",
    "perf:dl1:pan": "playwright test e2e/performance/dl1-diagnostics.spec.ts --grep \"dl1:pan\" --reporter=line",
    "perf:dl1:zoom": "playwright test e2e/performance/dl1-diagnostics.spec.ts --grep \"dl1:zoom\" --reporter=line",
    "perf:dl1:select": "playwright test e2e/performance/dl1-diagnostics.spec.ts --grep \"dl1:select\" --reporter=line",
    "perf:dl1:hover": "playwright test e2e/performance/dl1-diagnostics.spec.ts --grep \"dl1:hover\" --reporter=line",
    "perf:dl1:load": "playwright test e2e/performance/dl1-diagnostics.spec.ts --grep \"dl1:load\" --reporter=line",
    "perf:dl1:route-preview": "playwright test e2e/performance/dl1-diagnostics.spec.ts --grep \"dl1:route-preview\" --reporter=line"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.50.0",
    "@tanstack/react-query": "^5.66.0",
    "konva": "^10.2.0",
    "lucide-react": "^0.511.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.2.3",
    "react-router-dom": "^7.4.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@csstools/css-parser-algorithms": "^4.0.0",
    "@csstools/css-tokenizer": "^4.0.0",
    "@playwright/test": "^1.52.0",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/node": "^4.2.1",
    "@tailwindcss/oxide": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/react-test-renderer": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^29.1.1",
    "react-refresh": "^0.18.0",
    "react-test-renderer": "^19.2.4",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  }
}
